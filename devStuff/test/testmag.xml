                </StatusEffect> -->
            </Containable>
        </ItemContainer>
        <!--Magazines can be combined to raise condition.-->
        <Holdable canBeCombined="false" slots="Any,RightHand,LeftHand" handle1="0,0" msg="ItemMsgPickUpSelect" >
            <StatusEffect type="OnSpawn" target="This" condition="0.0" setvalue="true" disabledeltatime="true" AllowWhenBroken="true"/>
        </Holdable>
        <Upgrade gameversion="0.10.0.0" scale="0.5" />
