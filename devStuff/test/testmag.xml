                    <SpawnItem identifier="emptyMagVGMtest" spawnposition="sameinventory" spawnifinventoryfull="true" />
                    <Remove />
                </StatusEffect> -->
            </Containable>

            <!--Spawn an SMG round on use. Condition -4.8 -> 21 shots per magazine.-->
            <!-- <StatusEffect type="OnUse" target="This" condition="-4.8" disabledeltatime="true">
                <SpawnItem identifiers="smground" spawnposition="ThisInventory" />
            </StatusEffect> -->
            
            <SubContainer>
                <Containable identifier="smground">
                    <StatusEffect type="OnInserted" target="Contained" AllowWhenBroken="true" disabledeltatime="true">
                        <Conditional TargetContainer="true" condition="lt 100" />
                        <Remove />
                    </StatusEffect>
                    <StatusEffect type="OnInserted" target="This" condition="4.8" AllowWhenBroken="true" disabledeltatime="true" stackable="true">
                        <Conditional condition="lt 100" />
                    </StatusEffect>
                </Containable>
            </SubContainer>
            <StatusEffect type="OnBroken" target="This" AllowWhenBroken="true" disabledeltatime="true">
                <DropContainedItems />
                <SpawnItem identifier="emptyMagVGMtest" condition="0.0" spawnposition="sameinventory" spawnifinventoryfull="true" />
                <Remove />
            </StatusEffect>
        </ItemContainer>
        <!--Magazines can be combined to raise condition.-->
        <Upgrade gameversion="0.10.0.0" scale="0.5" />
    </Item>
    <Item name="Empty Magazine VGM Test" identifier="emptyMagVGMtest" maxstacksize="8" maxstacksizecharacterinventory="2" scale="0.5" category="Weapon" cargocontaineridentifier="metalcrate" linkable="true" tags="smallitem,smgammo,handheldammo" impactsoundtag="impact_metal_light">
        <!-- 当smgammo被去掉时，就会变成生成后因为Container不符强制弹出，可以做出类似M1弹匣弹出的效果 -->
        <InventoryIcon texture="Content/Items/InventoryIconAtlas.png" sourcerect="960,960,64,64" />
        <Sprite texture="Content/Items/Weapons/weapons_new.png" depth="0.54" sourcerect="146,157,21,44" origin="0.5,0.5" />
        <Body width="14" height="40" density="25" />
        <ItemContainer capacity="1" maxstacksize="1" keepopenwhenequipped="true" movableframe="true">
            <Containable items="smground">
                <StatusEffect type="OnInserted" target="This" AllowWhenBroken="true" disabledeltatime="true">
                    <SpawnItem identifier="smgMagVGMtest" condition="0.048" spawnposition="sameinventory"  spawnifinventoryfull="true" />
                    <!-- when in SpawnItem,  condition="1.0" == Max Condition -->
                    <Remove />
                </StatusEffect>
                <!-- <StatusEffect type="OnContaining" target="This" interval="1">
                    <SpawnItem identifier="SMG Magazine VGM Test" condition="0" spawnposition="sameinventory" spawnifinventoryfull="true" />
                    <SpawnItem identifier="iron" spawnposition="sameinventory" spawnifinventoryfull="true" />
