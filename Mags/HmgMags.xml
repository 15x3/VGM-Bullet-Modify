<?xml version="1.0" ?>
<Items>
    <Item name="" identifier="HmgMagBlank_VGB" maxstacksize="4" maxstacksizecharacterinventory="1" scale="0.5" category="Weapon" cargocontaineridentifier="metalcrate" linkable="true" tags="smallitem,hmgammo,handheldammo" impactsoundtag="impact_metal_light">
        <PreferredContainer primary="hmg" minamount="1" maxamount="1" spawnprobability="1" />
        <PreferredContainer primary="armcab" secondary="secarmcab" />
        <Deconstruct time="15">
            <Item identifier="steel" />
        </Deconstruct>
        <Sprite texture="Content/Items/Weapons/weapons_new.png" sourcerect="208,88,29,37" depth="0.55" origin="0.5,0.5" />
        <Body width="29" height="37" density="25" />
        <ItemContainer hideitems="true" capacity="1" maxstacksize="1" drawinventory="true" canbeselected="false" ShowConditionInContainedStateIndicator="true" removecontaineditemsondeconstruct="true" containedstateindicatorstyle="bullet">
            <StatusEffect type="Always" oneshot="true" target="This" delay="0.05" condition="100" AllowWhenBroken="false">
                <Conditional condition="eq 99" />
                <SpawnItem identifiers="556Blank_VGB" spawnposition="ThisInventory" targetcontainer="1" spawnifinventoryfull="false" />
            </StatusEffect>
            <!-- 确保当弹匣生成时有准备好的子弹，防止地图内生成的弹匣无法工作，不会在地图中刷新的物品不需要这段xml -->
            <Containable items="556Blank_VGB" >
                <StatusEffect type="OnRemoved" target="This" condition="-1.0" AllowWhenBroken="false">
                    <Conditional condition="gt 0" />
                </StatusEffect>
                <StatusEffect type="OnRemoved" target="This" AllowWhenBroken="false">
                    <Conditional condition="gt 0.001" />
                    <SpawnItem identifiers="556Blank_VGB" spawnposition="ThisInventory" spawnifinventoryfull="false" />
                </StatusEffect>
                <!-- 子弹开火(OnRemoved)时,减少耐久,生成对应的子弹 -->
            </Containable>
            <SubContainer maxstacksize="32">
                <!-- 最大堆叠设置为32,防止因栈溢出出现弹匣复制问题 -->
                <Containable identifier="556Blank_VGB">
                    <StatusEffect type="OnInserted" target="Contained" AllowWhenBroken="false" disabledeltatime="true" >
                        <Conditional TargetContainer="true" condition="eq 100" />
                        <Remove /> 
                        <SpawnItem identifiers="556Blank_VGB" spawnposition="SameInventory" spawnifinventoryfull="false" />
                    </StatusEffect>
                    <!-- 当弹匣已满依旧塞入子弹时,子弹还是会消失,不过会在玩家物品栏中重新生成对应的多余子弹 -->
                    <StatusEffect type="OnInserted" target="Contained" AllowWhenBroken="false" disabledeltatime="true">
                        <Conditional TargetContainer="true" condition="lt 100" />
                        <Remove /> </StatusEffect>
                    <StatusEffect type="OnInserted" target="This" condition="1.0" AllowWhenBroken="true" disabledeltatime="true" />
                    <!-- 子弹压入时,增加耐久,并让子弹消失 -->
                </Containable>
            </SubContainer>
            <StatusEffect type="OnBroken" target="This" AllowWhenBroken="true" disabledeltatime="true">
                <SpawnItem identifier="EmptyHmgMag_VGM" condition="0.0" spawnposition="sameinventory" spawnifinventoryfull="true" />
                <Remove />
            </StatusEffect>
            <!-- 耐久为0时生成空弹匣 -->
            <StatusEffect type="Always" oneshot="true" target="This" condition="1.0" setvalue="true" delay="0.1" AllowWhenBroken="false">
                <Conditional condition="eq 0.1" />
                <SpawnItem identifiers="556Blank_VGB" spawnposition="ThisInventory" targetcontainer="1" spawnifinventoryfull="false" />
            </StatusEffect>
            <!-- 当弹匣以压入的形式生成时，将condition设置为正确值，并在弹匣内生成一发子弹，确保弹匣能正常工作 -->
            <!-- 别问我为什么不用OnSpawn和SpawnWithID，这俩B会在地图加载时自动触发一次 -->
        </ItemContainer>
    </Item>
</Items>